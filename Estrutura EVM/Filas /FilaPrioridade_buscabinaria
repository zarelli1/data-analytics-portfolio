pragma solidity ^0.8.0;

contract FilaPrioridade {

    struct Cliente {
        address endereco;  
        uint8 gravidade;   
        uint256 chegada;   
    }

    Cliente[] public fila;
    uint256 private contador;

    function entrar(uint8 _gravidade) external {
        require(_gravidade >= 1 && _gravidade <= 10, "Gravidade invalida");
        fila.push(Cliente(msg.sender, _gravidade, contador));
        contador++;
        _ordenar(); 
    }

    function _ordenar() internal {
        uint256 i = fila.length - 1;
        while (i > 0) {
            uint256 j = i - 1;
            if (_temPrioridade(fila[i], fila[j])) { 
                Cliente memory temp = fila[i];
                fila[i] = fila[j];
                fila[j] = temp;
                i = j;
            } else {
                break;
            }
        }
    }
    function _temPrioridade(Cliente memory a, Cliente memory b) internal pure returns (bool) {
        if (a.gravidade != b.gravidade) {
            return a.gravidade > b.gravidade;
        }
        return a.chegada < b.chegada;
    }

    function atender() external returns (address) {
        require(fila.length > 0, "Fila vazia");
        address atendido = fila[0].endereco;
        for (uint256 i = 0; i < fila.length - 1; i++) {
            fila[i] = fila[i + 1];
        }
        fila.pop();
        return atendido;
    }

// ─── A BUSCA BINÁRIA CIRÚRGICA ───────────────────────────
    
    function buscarPorGravidade(uint8 _alvo) external view returns (bool encontrado, uint256 posicao, address cliente) {
        if (fila.length == 0) return (false, 0, address(0));

        uint256 esq = 0;
        uint256 dir = fila.length - 1;

        while (esq <= dir) {
            uint256 meio = esq + (dir - esq) / 2;

            if (fila[meio].gravidade == _alvo) {
                // Achou! Mas como podem ter várias pessoas com gravidade 8,
                // precisamos recuar para pegar o PRIMEIRO da fila com essa gravidade.
                uint256 primeiro = meio;
                while (primeiro > 0 && fila[primeiro - 1].gravidade == _alvo) {
                    primeiro--;
                }
                return (true, primeiro, fila[primeiro].endereco);
            }

            // ATENÇÃO À ORDEM: A fila é DECRESCENTE (10, 9, 8...)
            if (fila[meio].gravidade > _alvo) {
                // Se eu achei um 9 e procuro um 8, o 8 está mais pro final (direita)
                esq = meio + 1;
            } else {
                // Se eu achei um 7 e procuro um 8, o 8 está mais pro começo (esquerda)
                if (meio == 0) break; // Previne underflow de uint256
                dir = meio - 1;
            }
        }

        return (false, 0, address(0)); // Não encontrou ninguém com essa gravidade
}

    function verFila() external view returns (Cliente[] memory) {
        return fila;
    }

    function tamanho() external view returns (uint256) {
        return fila.length;
    }
}
